# vLLM API 설정 (OpenAI Compatible)
# vLLM 서버 주소와 API 키를 설정합니다.

# vLLM API 기본 URL
VLLM_API_BASE=your-vllm-server-url

# vLLM API 키
VLLM_API_KEY=your-api-key

# 사용할 모델 이름 (vLLM 에서 로드된 모델)
VLLM_MODEL_NAME=your-model-name

# ==========================================
# 선택 사항: 벡터 데이터베이스 설정
# ==========================================

# Chroma DB 저장 경로 (로컬 사용 시)
CHROMA_DB_PATH=./chroma_db

# Pinecone API 설정 (클라우드 사용 시)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-west1-gcp-free

# ==========================================
# 선택 사항: 기타 API 설정
# ==========================================

# OpenAI API (대체용으로 사용 시)
OPENAI_API_KEY=your-openai-api-key

# LangChain 로깅 활성화
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
